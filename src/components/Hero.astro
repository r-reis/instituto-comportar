---
import { site } from "../content/site";
const base = import.meta.env.BASE_URL;
const { hero, contato } = site;
const wa = `https://wa.me/${contato.whatsapp}?text=${encodeURIComponent(
  contato.mensagemWhatsapp
)}`;
---

<section class="hero" id="inicio">
  <span class="blob blob-a"></span>
  <span class="blob blob-b"></span>

  <div class="container hero-grid">
    <div class="hero-photo reveal">
      <div class="photo-frame">
        <img src={`${base}${hero.foto}`} alt={hero.fotoAlt} />
      </div>
      <span class="leaf leaf-1" aria-hidden="true">🌿</span>
    </div>

    <div class="hero-copy reveal">
      <span class="eyebrow">{hero.saudacao}</span>
      <h1>{hero.titulo}</h1>
      <p class="hero-lead">{hero.descricao}</p>
      <div class="hero-actions">
        <a href={wa} target="_blank" rel="noopener" class="btn btn-primary"
          >{hero.cta}</a
        >
        <a href="#especialidades" class="btn btn-ghost">{hero.ctaSecundario}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(48px, 8vw, 96px);
    overflow: hidden;
  }
  .blob-a {
    width: 480px;
    height: 480px;
    --blob-color: var(--lavanda-200);
    top: -140px;
    right: -120px;
  }
  .blob-b {
    width: 360px;
    height: 360px;
    --blob-color: var(--salvia-claro);
    bottom: -160px;
    left: -120px;
  }
  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    align-items: center;
    gap: clamp(32px, 6vw, 72px);
  }
  .hero-photo {
    position: relative;
    justify-self: center;
  }
  .photo-frame {
    width: clamp(260px, 34vw, 400px);
    aspect-ratio: 4 / 5;
    border-radius: 48% 48% 46% 46% / 40% 40% 60% 60%;
    overflow: hidden;
    box-shadow: var(--sombra-forte);
    border: 6px solid var(--branco);
  }
  .photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .leaf {
    position: absolute;
    bottom: 8px;
    left: -10px;
    font-size: 2.2rem;
    filter: drop-shadow(0 6px 10px rgba(47, 29, 74, 0.2));
  }
  .hero-copy h1 {
    font-size: clamp(2.3rem, 5.2vw, 3.8rem);
    margin-bottom: 20px;
  }
  .hero-lead {
    font-size: 1.15rem;
    color: var(--tinta-suave);
    max-width: 52ch;
    margin-bottom: 32px;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  @media (max-width: 860px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-photo {
      order: -1;
    }
    .hero-lead {
      margin-inline: auto;
    }
    .hero-actions {
      justify-content: center;
    }
  }
</style>
