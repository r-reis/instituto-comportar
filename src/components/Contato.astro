---
import { site } from "../content/site";
const { contato } = site;
const wa = `https://wa.me/${contato.whatsapp}?text=${encodeURIComponent(
  contato.mensagemWhatsapp
)}`;
const mapSrc = contato.mapaQuery
  ? `https://www.google.com/maps?q=${encodeURIComponent(
      contato.mapaQuery
    )}&output=embed`
  : "";
---

<section class="section contato" id="contato">
  <span class="blob blob-e"></span>
  <div class="container">
    <div class="head reveal">
      <span class="eyebrow">{site.menu.contato}</span>
      <h2 class="section-title">{contato.titulo}</h2>
      <p class="section-lead">{contato.subtitulo}</p>
    </div>

    <div class="contato-grid">
      <div class="info reveal">
        <a href={wa} target="_blank" rel="noopener" class="info-item destaque">
          <span class="info-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm5.8 14.13c-.25.69-1.43 1.32-1.97 1.4-.5.08-1.15.11-1.85-.12-.43-.14-.98-.32-1.69-.62-2.97-1.28-4.91-4.27-5.06-4.47-.15-.2-1.21-1.61-1.21-3.07 0-1.46.77-2.18 1.04-2.48.27-.3.59-.37.79-.37.2 0 .39 0 .56.01.18.01.42-.07.66.5.25.59.84 2.04.91 2.19.07.15.12.32.02.52-.1.2-.15.32-.3.49-.15.18-.31.39-.45.53-.15.15-.3.31-.13.6.17.3.76 1.25 1.63 2.02 1.12.99 2.06 1.3 2.36 1.45.3.15.47.12.64-.07.17-.2.74-.86.94-1.16.2-.3.39-.25.66-.15.27.1 1.72.81 2.01.96.3.15.5.22.57.35.07.13.07.74-.18 1.43Z"
              /></svg
            >
          </span>
          <span>
            <strong>WhatsApp</strong>
            <small>{contato.whatsappLabel}</small>
          </span>
        </a>

        <a href={`mailto:${contato.email}`} class="info-item">
          <span class="info-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
          </span>
          <span>
            <strong>E-mail</strong>
            <small>{contato.email}</small>
          </span>
        </a>

        <div class="info-item static">
          <span class="info-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          </span>
          <span>
            <strong>Endereço</strong>
            <small>{contato.endereco}</small>
          </span>
        </div>

        <div class="info-item static">
          <span class="info-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
          </span>
          <span>
            <strong>Horário</strong>
            <small>{contato.horario}</small>
          </span>
        </div>

        <div class="social">
          <a href={contato.instagramUrl} target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            <span>{contato.instagram}</span>
          </a>
        </div>
      </div>

      <div class="map reveal">
        {
          mapSrc ? (
            <iframe
              src={mapSrc}
              title="Localização do consultório"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            />
          ) : (
            <div class="map-placeholder">
              <p>📍 O mapa aparece aqui quando você preencher o endereço.</p>
              <small>Edite <code>contato.mapaQuery</code> em src/content/site.ts</small>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .contato {
    background: linear-gradient(180deg, var(--lavanda) 0%, var(--creme) 100%);
    overflow: hidden;
  }
  .blob-e {
    width: 420px;
    height: 420px;
    --blob-color: var(--salvia-claro);
    bottom: -180px;
    right: -160px;
    opacity: 0.4;
  }
  .head {
    text-align: center;
    margin-bottom: 52px;
  }
  .head .section-lead {
    margin-inline: auto;
  }
  .contato-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 36px;
    align-items: stretch;
  }
  .info {
    display: grid;
    gap: 14px;
    align-content: start;
  }
  .info-item {
    display: flex;
    align-items: center;
    gap: 16px;
    background: var(--branco);
    border: 1px solid rgba(74, 44, 109, 0.06);
    border-radius: var(--raio-sm);
    padding: 16px 20px;
    box-shadow: var(--sombra-suave);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  a.info-item:hover {
    transform: translateY(-3px);
    box-shadow: var(--sombra-forte);
  }
  .info-item.destaque {
    background: var(--roxo-700);
    color: var(--branco);
  }
  .info-item.destaque .info-icon {
    background: rgba(255, 255, 255, 0.18);
    color: var(--branco);
  }
  .info-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 12px;
    background: var(--lavanda);
    color: var(--roxo-600);
    flex-shrink: 0;
  }
  .info-item span:last-child {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }
  .info-item strong {
    font-size: 1rem;
  }
  .info-item small {
    font-size: 0.9rem;
    opacity: 0.85;
  }
  .social {
    margin-top: 6px;
  }
  .social a {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    color: var(--roxo-700);
    padding: 10px 4px;
  }
  .social a:hover {
    color: var(--roxo-500);
  }
  .map {
    border-radius: var(--raio);
    overflow: hidden;
    box-shadow: var(--sombra-suave);
    min-height: 360px;
    border: 6px solid var(--branco);
  }
  .map iframe {
    width: 100%;
    height: 100%;
    min-height: 360px;
    border: 0;
    display: block;
  }
  .map-placeholder {
    height: 100%;
    min-height: 360px;
    display: grid;
    place-content: center;
    text-align: center;
    gap: 10px;
    padding: 24px;
    background: var(--salvia-claro);
    color: var(--tinta-suave);
  }
  .map-placeholder code {
    background: var(--branco);
    padding: 2px 6px;
    border-radius: 6px;
    font-size: 0.85em;
  }

  @media (max-width: 860px) {
    .contato-grid {
      grid-template-columns: 1fr;
    }
    .info {
      gap: 10px;
    }
    .info-item {
      padding: 10px 12px;
      gap: 0;
      min-width: 0;
    }
    .info-icon {
      width: 40px;
      height: 40px;
      min-width: 40px;
    }
    .info-item span:last-child {
      margin-left: 12px;
      min-width: 0;
      overflow: hidden;
    }
    .info-item strong {
      font-size: 0.9rem;
    }
    .info-item small {
      font-size: 0.8rem;
    }
    .map {
      min-height: 280px;
    }
    .map iframe {
      min-height: 280px;
    }
  }
</style>
