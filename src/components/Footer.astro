---
import { site } from "../content/site";
const base = import.meta.env.BASE_URL;
const ano = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <a href="#topo" class="footer-brand">
      <img src={`${base}${site.logo}`} alt={site.nome} />
      <span>{site.nome}</span>
    </a>
    <p class="footer-copy">© {ano} {site.rodape.direitos}</p>
    <a
      href={site.contato.instagramUrl}
      target="_blank"
      rel="noopener"
      class="footer-social"
      aria-label="Instagram"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
    </a>
  </div>
</footer>

<style>
  .footer {
    background: var(--roxo-900);
    color: rgba(255, 255, 255, 0.82);
    padding-block: 36px;
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--fonte-titulo);
    font-size: 1.1rem;
    color: var(--branco);
  }
  .footer-brand img {
    width: 38px;
    height: 38px;
    object-fit: contain;
    background: var(--branco);
    border-radius: 50%;
    padding: 4px;
  }
  .footer-copy {
    font-size: 0.9rem;
  }
  .footer-social {
    display: inline-flex;
    width: 42px;
    height: 42px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    color: var(--branco);
    transition: background 0.25s ease;
  }
  .footer-social:hover {
    background: rgba(255, 255, 255, 0.22);
  }

  @media (max-width: 600px) {
    .footer-inner {
      justify-content: center;
      text-align: center;
    }
  }
</style>
