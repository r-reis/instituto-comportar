---
import "../styles/global.css";
import { site } from "../content/site";

const base = import.meta.env.BASE_URL;
const ogImage = `${base}${site.logo}`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{site.nome} — {site.subtitulo}</title>
    <meta name="description" content={site.descricao} />
    <link rel="icon" type="image/png" href={`${base}${site.logo}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${site.nome} — ${site.subtitulo}`} />
    <meta property="og:description" content={site.descricao} />
    <meta property="og:image" content={ogImage} />

    <!-- Fontes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <script>
      // Scroll reveal — anima elementos .reveal ao entrarem na tela
      const reveals = document.querySelectorAll(".reveal");
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );
      reveals.forEach((el) => io.observe(el));
    </script>
  </body>
</html>
